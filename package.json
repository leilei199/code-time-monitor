{
  "name": "code-time-monitor",
  "version": "5.0.2",
  "description": "一个基于 Node.js 的编码时间监控工具，帮助开发者管理编码时间，避免过度编码",
  "main": "src/app.js",
  "type": "module",
  "bin": {
    "ctm": "src/cli/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop code-time-monitor",
    "pm2:restart": "pm2 restart code-time-monitor",
    "pm2:delete": "pm2 delete code-time-monitor",
    "pm2:logs": "pm2 logs code-time-monitor",
    "pm2:status": "pm2 status",
    "pm2:startup": "pm2 startup && pm2 save",
    "add-project": "node src/cli/index.js add-project",
    "stats": "node src/cli/index.js stats",
    "config": "node src/cli/index.js config",
    "status": "node src/cli/index.js status",
    "migrate": "node scripts/migrate.js"
  },
  "keywords": [
    "time-tracking",
    "developer-tools",
    "productivity",
    "monitor"
  ],
  "author": "daleilei",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "dayjs": "^1.11.10",
    "inquirer": "^9.2.23",
    "menubar": "^9.5.2",
    "node-notifier": "^10.0.1",
    "ora": "^8.0.1",
    "pm2": "^5.4.2",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src",
    "templates",
    "scripts",
    "ecosystem.config.cjs",
    "icons"
  ]
}
